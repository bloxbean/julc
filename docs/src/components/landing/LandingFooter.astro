---
const columns = [
  {
    title: 'Project',
    links: [
      { label: 'GitHub', href: 'https://github.com/bloxbean/julc' },
      { label: 'Documentation', href: '/overview/' },
      { label: 'Examples', href: '/reference/examples/' },
      { label: 'Hello World', href: 'https://github.com/bloxbean/julc-helloworld' },
    ],
  },
  {
    title: 'Built By',
    links: [
      { label: 'BloxBean', href: 'https://github.com/bloxbean' },
      { label: 'cardano-client-lib', href: 'https://github.com/bloxbean/cardano-client-lib' },
    ],
  },
  {
    title: 'Ecosystem',
    links: [
      { label: 'Cardano', href: 'https://cardano.org' },
      { label: 'Cardano Client Lib', href: 'https://github.com/bloxbean/cardano-client-lib' },
      { label: 'Yaci', href: 'https://github.com/bloxbean/yaci' },
      { label: 'Yaci Store', href: 'https://github.com/bloxbean/yaci-store' },
    ],
  },
]
---
<footer class="border-t border-white/5 bg-[#0a0a0f] py-16">
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid gap-10 sm:grid-cols-3">
      {columns.map((col) => (
        <div>
          <h3 class="text-sm font-semibold text-white">{col.title}</h3>
          <ul class="mt-4 space-y-2.5">
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-[#a1a1aa] hover:text-[#D4600E] transition-colors"
                  {...(link.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <div class="mt-14 border-t border-white/5 pt-8 flex items-center justify-between">
      <div class="flex items-center gap-2">
        <span class="text-sm font-semibold text-white font-[var(--font-mono)]">JuLC</span>
      </div>
      <p class="text-xs text-[#6b7280]">MIT &copy; {new Date().getFullYear()} BloxBean</p>
    </div>
  </div>
</footer>
