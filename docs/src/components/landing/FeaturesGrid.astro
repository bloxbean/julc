---
const features = [
  {
    title: 'Java-to-UPLC Compiler',
    description: 'Compiles records, sealed interfaces, switch expressions, lambdas, and loops to efficient Plutus V3 UPLC.',
    icon: `<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/><polyline points="10 17 8 15 10 13"/><polyline points="14 17 16 15 14 13"/></svg>`,
  },
  {
    title: 'Pluggable VM',
    description: 'Evaluate UPLC locally via SPI. Ships with Scalus and pure-Java backends for testing and cost estimation.',
    icon: `<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/></svg>`,
  },
  {
    title: 'Standard Library',
    description: '13 on-chain libraries: lists, maps, values, math, crypto, bitwise, intervals, output, address, and more.',
    icon: `<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>`,
  },
  {
    title: 'Testkit',
    description: 'Test validators locally without a running node. Unit tests, property-based fuzzing, and budget analysis.',
    icon: `<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>`,
  },
  {
    title: 'IDE Support',
    description: 'Full IntelliJ / VS Code support with autocomplete, error checking, and debugging for validator code.',
    icon: `<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
  },
  {
    title: 'CLI Toolkit',
    description: 'julc CLI: scaffold projects, compile, test, and explore with an interactive REPL from your terminal.',
    icon: `<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>`,
  },
]
---
<section class="bg-[#111118] py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <h2 class="text-center text-3xl font-bold tracking-tight text-white sm:text-4xl">
      Everything you need
    </h2>
    <p class="mt-4 text-center text-[#a1a1aa] max-w-2xl mx-auto">
      A complete toolchain from writing your first validator to deploying on mainnet.
    </p>
    <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((f) => (
        <div class="group rounded-xl border border-white/5 bg-white/[0.02] p-6 transition-all duration-300 hover:border-[#D4600E]/20 hover:bg-white/[0.04]">
          <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-[#D4600E]/10 text-[#D4600E]" set:html={f.icon} />
          <h3 class="font-semibold text-white">{f.title}</h3>
          <p class="mt-2 text-sm text-[#a1a1aa] leading-relaxed">{f.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
