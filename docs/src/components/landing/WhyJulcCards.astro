---
const cards = [
  {
    title: 'Java Ecosystem',
    description: 'Use your existing IDE, debugger, Maven/Gradle. Java developers can now write Cardano smart contracts.',
    icon: `<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/><line x1="14" y1="4" x2="10" y2="20"/></svg>`,
  },
  {
    title: 'Type-Safe',
    description: 'Records, sealed interfaces, switch expressions, and exhaustiveness checking catch bugs at compile time.',
    icon: `<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>`,
  },
  {
    title: 'Debug Like Java',
    description: 'Step through validators in your IDE. Source maps pinpoint exactly where your UPLC crashed on-chain.',
    icon: `<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>`,
  },
  {
    title: 'Batteries Included',
    description: 'Rich standard library, testkit, Gradle plugin, annotation processor, and cardano-client-lib integration.',
    icon: `<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
  },
]
---
<section class="bg-[#111118] py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <h2 class="text-center text-3xl font-bold tracking-tight text-white sm:text-4xl">
      Why JuLC?
    </h2>
    <p class="mt-4 text-center text-[#a1a1aa] max-w-2xl mx-auto">
      Write Cardano smart contracts in Java — one of the most popular languages in enterprise.
    </p>
    <div class="mt-14 grid gap-6 sm:grid-cols-2">
      {cards.map((card) => (
        <div class="group rounded-xl border border-white/5 bg-white/[0.02] p-8 transition-all duration-300 hover:border-[#D4600E]/30 hover:bg-white/[0.04] hover:shadow-lg hover:shadow-[#D4600E]/5">
          <div class="mb-5 flex h-11 w-11 items-center justify-center rounded-lg bg-[#D4600E]/10 text-[#D4600E]" set:html={card.icon} />
          <h3 class="text-lg font-semibold text-white">{card.title}</h3>
          <p class="mt-2.5 text-[#a1a1aa] leading-relaxed">{card.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
